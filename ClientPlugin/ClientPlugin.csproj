             libopenal.so.1 resolves via ldconfig at runtime (provided by libopenal1
             Debian package on the host, by org.freedesktop.Platform on the Flatpak,
             and bundled into the developer-bundle's Pulsar/Libraries folder). -->
        <PackageReference Include="Silk.NET.OpenAL" Version="2.23.0" />
    </ItemGroup>

