    <!-- Deploy LinuxCompat.dll to the Pulsar Local plugins folder
         (~/.config/Pulsar/Local) so Pulsar picks it up automatically.
         Overwrites any existing file at that path. -->
    <Target Name="DeployToPulsarLocal"
            AfterTargets="Build"
            Condition="'$(OS)' != 'Windows_NT'">
        <PropertyGroup>
            <PulsarLocalDir>$(HOME)/.config/Pulsar/Local</PulsarLocalDir>
        </PropertyGroup>
        <MakeDir Directories="$(PulsarLocalDir)" />
        <Copy SourceFiles="$(OutputPath)$(AssemblyName).dll"
              DestinationFolder="$(PulsarLocalDir)"
              OverwriteReadOnlyFiles="true" />
    </Target>

    <!-- Stage FFmpeg.AutoGen.dll into the Pulsar dev build's probe path
         (Bin/Libraries/Interim) so audio/video work when running the Interim
         dev binary directly (e.g. via the Rider run config). The deployed
         bundle stages this via Scripts/package_pulsar_for_linux.sh. -->
    <Target Name="StageFFmpegForPulsarDev"
            AfterTargets="Build"
            Condition="Exists('$(MSBuildThisFileDirectory)..\..\Pulsar\Legacy\bin\$(Configuration)\net10.0')">
        <PropertyGroup>
            <PulsarDevLibrariesInterim>$(MSBuildThisFileDirectory)..\..\Pulsar\Legacy\bin\$(Configuration)\net10.0\Libraries\Interim</PulsarDevLibrariesInterim>
        </PropertyGroup>
        <MakeDir Directories="$(PulsarDevLibrariesInterim)" />
        <Copy SourceFiles="$(PkgFFmpeg_AutoGen)\lib\netstandard2.1\FFmpeg.AutoGen.dll"
              DestinationFolder="$(PulsarDevLibrariesInterim)"
              SkipUnchangedFiles="true" />
    </Target>

    <!-- Stage Silk.NET.OpenAL + Silk.NET.Core into the Pulsar dev probe path.
         OpenAL Soft (libopenal.so.1) is provided by the host (libopenal1
         Debian package) or the bundle's Pulsar/Libraries folder, so only
         the managed bindings need staging here. -->
    <Target Name="StageSilkNetOpenALForPulsarDev"
            AfterTargets="Build"
            Condition="Exists('$(MSBuildThisFileDirectory)..\..\Pulsar\Legacy\bin\$(Configuration)\net10.0')">
        <PropertyGroup>
            <PulsarDevLibrariesInterim>$(MSBuildThisFileDirectory)..\..\Pulsar\Legacy\bin\$(Configuration)\net10.0\Libraries\Interim</PulsarDevLibrariesInterim>
            <SilkNuGetRoot>$(NuGetPackageRoot)</SilkNuGetRoot>
            <SilkNuGetRoot Condition="'$(SilkNuGetRoot)' == ''">$(HOME)/.nuget/packages/</SilkNuGetRoot>
        </PropertyGroup>
        <MakeDir Directories="$(PulsarDevLibrariesInterim)" />
        <Copy SourceFiles="$(SilkNuGetRoot)silk.net.openal/2.23.0/lib/netstandard2.1/Silk.NET.OpenAL.dll"
              DestinationFolder="$(PulsarDevLibrariesInterim)"
              SkipUnchangedFiles="true" />
        <Copy SourceFiles="$(SilkNuGetRoot)silk.net.core/2.23.0/lib/netstandard2.1/Silk.NET.Core.dll"
              DestinationFolder="$(PulsarDevLibrariesInterim)"
              SkipUnchangedFiles="true" />
    </Target>

</Project>
